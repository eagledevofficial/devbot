# Eagle Trader Configuration
# Copy this to .env and fill in your values

# Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Bot Token (required for Discord integration)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel IDs (optional - auto-detected if not set)
DISCORD_TRADING_CHANNEL_ID=
DISCORD_ALERTS_CHANNEL_ID=

# Paper Trading Config
STARTING_BALANCE=100000.00
MAX_POSITION_SIZE=0.10
MAX_POSITIONS=10

# Trading Schedule (24h format, EST)
MARKET_OPEN=09:30
MARKET_CLOSE=16:00

# Watchlist (comma-separated tickers)
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,SPY,QQQ
